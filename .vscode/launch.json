{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask App (WSL)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "app.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-debugger",
                "--no-reload",
                "--port", "8080"
            ],
            "jinja": true,
            "justMyCode": true
       },
    {
            "name": "Launch Chrome (JS Debug)",
            "type": "chrome",
            "request": "launch",
            "url": "http://127.0.0.1:8080",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Debug Flask + JavaScript",
            "configurations": [
                "Python: Flask App (WSL)",
                "Launch Chrome (JS Debug)"
            ]
        }
    ]
   
}